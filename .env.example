# AgentOS Environment Configuration

# Application Settings
APP_NAME=AgentOS
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentos_db
DB_USER=agentos
DB_PASSWORD=agentos_secret

# LLM Providers (API keys read via Pydantic Settings)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Security Settings
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ALLOWED_HOSTS=["*"]
